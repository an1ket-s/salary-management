generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phone       String
  role        String
  department  String
  country     String
  salary      Float
  email       String   @unique
  joiningDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Insights hiring-trend queries
  @@index([joiningDate])
  @@index([country, joiningDate])

  // No-filter — sort only
  @@index([createdAt])
  @@index([salary])

  // Single filter + sort
  @@index([country, createdAt])
  @@index([country, salary])
  @@index([department, createdAt])
  @@index([department, salary])
  @@index([role, createdAt])
  @@index([role, salary])

  // Two-filter combos + sort
  @@index([country, department, createdAt])
  @@index([country, department, salary])
  @@index([country, role, createdAt])
  @@index([country, role, salary])
  @@index([department, role, createdAt])
  @@index([department, role, salary])

  // All three filters + sort
  @@index([country, department, role, createdAt])
  @@index([country, department, role, salary])
}

model NameBank {
  id    Int    @id @default(autoincrement())
  value String
  type  String

  @@index([type])
}
